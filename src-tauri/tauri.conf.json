{
  "build": {
    
    
    "devPath": "http://localhost:1420"
    "distDir": ".."
  },
  "package": {
    "productName": "usina-overlay",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "globalShortcut": { "all": true },
      "window": { "all": true }
    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": false,
        "title": "Usina Overlay",
        "width": 1920,
        "height": 1080,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ],
    "security": { "csp": null }
  }
}
